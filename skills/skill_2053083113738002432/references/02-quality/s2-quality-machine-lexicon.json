{
  "schemaVersion": "1.0",
  "description": "S2 机器可检词表（与 quality-S.md、quality-auditor、quick-scan 单一真源对齐；更新后须跑 npm run audit:consistency）",
  "safeAdverbs": [
    "非常", "显著", "大幅", "彻底", "极其", "极大地", "深刻地", "全面地", "前所未有", "充分", "尤其", "特别", "相当", "格外", "甚为", "甚", "根本", "高度", "深入"
  ],
  "imperativeClassA": [
    "必须", "务必", "一定", "绝不能", "无论如何"
  ],
  "protectedPhrases": [
    "深度学习", "深度阅读", "深度工作", "深度理解", "高度不确定", "高度专业", "高度复杂"
  ],
  "imperativeAutoFixMap": {
    "无论如何": "总之",
    "绝不能": "应避免"
  },
  "safeAdverbAutoFixMap": {
    "非常": "很",
    "显著": "明显",
    "大幅": "较大",
    "彻底": "充分",
    "极其": "很",
    "极大地": "明显",
    "深刻地": "深入",
    "全面地": "从各方面",
    "前所未有": "少见",
    "充分": "足够",
    "尤其": "特别是",
    "特别": "尤其",
    "相当": "相当",
    "格外": "尤其",
    "甚为": "颇为",
    "甚": "很",
    "根本": "基本",
    "高度": "很高",
    "深入": "进一步"
  },
  "notes": [
    "imperativeAutoFixMap 仅用于 --auto-fix 候选稿；A 类词之间禁止互转（见复盘报告）",
    "全书 A 类词合计阈值见 quality-S.md；机器扫描用 quality-auditor --glob 汇总",
    "脚本层 imperativeHitsForText 会对「不一定」「一定规模」「有了一定」等非命令语境做弱化，以降低误标（与 quick-scan 内置词表互补）"
  ]
}
